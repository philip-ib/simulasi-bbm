# ============================================================
# KONFIGURASI ENVIRONMENT UNTUK SIMULASI BBM
# ============================================================
# Copy file ini ke .env dan isi nilainya

# Database PostgreSQL (gunakan Neon, Railway, atau Supabase)
# Contoh: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret Key untuk JWT (gunakan string acak yang panjang)
SECRET_KEY=your-secret-key-ganti-ini

# (Opsional) CORS — domain yang diizinkan (pisahkan dengan koma)
ALLOWED_ORIGIN=https://simulasi-bbm-pertamina.vercel.app

# (Opsional) Username & Password Admin default
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
